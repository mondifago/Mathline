@page "/"
@using Core.Models
@using Core.Parsing
@using Core.Solving

<h1>Mathline</h1>

<div class="solver">
    <input @bind="input"
           @bind:event="oninput"
           @onkeyup="OnKeyUp"
           placeholder="e.g. 3x + 5 = 14"
           class="equation-input" />
    <button @onclick="Solve" class="solve-button">Solve</button>
</div>

@if (error is not null)
{
    <p class="error">@error</p>
}
else if (result is not null)
{
    <div class="result">
        <ol>
            @foreach (var step in result.Steps)
            {
                <li>
                    <span class="step-description">@step.Description</span>
                    <span class="step-expression">@step.Expression</span>
                </li>
            }
        </ol>
        <p class="method">Method: @result.Method</p>
        <p class="solution">x = @result.Solution.X</p>
    </div>
}

@code {
    private string input = "";
    private SolveResult<LinearEquationSolution>? result;
    private string? error;

    private void Solve()
    {
        try
        {
            var tokens = Tokenizer.Tokenize(input);
            var terms = TermCollector.Collect(tokens);
            var equation = LinearBuilder.Build(terms);
            result = SolvingLogic.SolveLinearEquation(equation);
            error = null;
        }
        catch (Exception ex) when (ex is FormatException or ArgumentException)
        {
            result = null;
            error = ex.Message;
        }
    }

    private void OnKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            Solve();
    }
}