@page "/"
@using Core
@using Core.Parsing

<h1>Mathline</h1>

<div class="solver">
    <input @bind="input"
           @bind:event="oninput"
           @onkeyup="OnKeyUp"
           placeholder="e.g. 3x + 5 = 14   or   x^2 - 5x + 6 = 0"
           class="equation-input" />
    <button @onclick="Solve" class="solve-button">Solve</button>
</div>

@if (error is not null)
{
    <p class="error">@error</p>
}
else if (outcome is not null)
{
    <div class="result">
        <p class="equation-type">
            @(outcome.Type == EquationType.Quadratic ? "Quadratic equation" : "Linear equation")
        </p>
        <ol>
            @foreach (var step in outcome.Steps)
            {
                <li>
                    <span class="step-description">@step.Description</span>
                    <span class="step-expression">@step.Expression</span>
                </li>
            }
        </ol>
        <p class="method">Method: @outcome.Method</p>
    </div>
}

@code {
    private string input = "";
    private SolveOutcome? outcome;
    private string? error;

    private void Solve()
    {
        try
        {
            outcome = Coordinator.Solve(input);
            error = null;
        }
        catch (Exception ex) when (ex is FormatException or ArgumentException)
        {
            outcome = null;
            error = ex.Message;
        }
    }

    private void OnKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            Solve();
    }
}