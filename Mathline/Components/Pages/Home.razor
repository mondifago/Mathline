@page "/"
@using Core.Coordination
@using Core.Models

<h1>Mathline</h1>

<div class="solver">
    <textarea @bind="input"
              @bind:event="oninput"
              rows="2"
              placeholder=""
              class="equation-input"></textarea>
    <button @onclick="Solve" class="solve-button">Solve</button>
</div>

@if (error is not null)
{
    <p class="error">@error</p>
}
else if (outcome is not null)
{
    <div class="result">
        <p class="equation-type">@TypeLabel(outcome.Type)</p>
        <ol>
            @foreach (var step in outcome.Steps)
            {
                <li>
                    <span class="step-description">@step.Description</span>
                    <span class="step-expression">@step.Expression</span>
                </li>
            }
        </ol>
        <p class="method">Method: @outcome.Method</p>
    </div>
}

@code {
    private string input = "";
    private SolveOutcome? outcome;
    private string? error;

    private void Solve()
    {
        try
        {
            outcome = Coordinator.Solve(input);
            error = null;
        }
        catch (Exception ex) when (ex is FormatException or ArgumentException)
        {
            outcome = null;
            error = ex.Message;
        }
    }

    private static string TypeLabel(EquationType type) => type switch
    {
        EquationType.Linear => "Linear equation",
        EquationType.Quadratic => "Quadratic equation",
        EquationType.Simultaneous => "Simultaneous equations",
        _ => ""
    };
}